<Window x:Class="AudioStretch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AudioStretch"
        Title="AudioStretch" Height="720" Width="620"
        MinWidth="460" MinHeight="520"
        Background="{StaticResource WindowBg}"
        ResizeMode="CanResize">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolVis"/>
        <local:InverseBoolConverter x:Key="InvBool"/>
    </Window.Resources>

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="210"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBg}" Padding="16,12">
            <TextBlock Text="AudioStretch" FontSize="20" FontWeight="Bold"/>
        </Border>

        <!-- Controls -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,14,16,6">
            <StackPanel>

                <!-- Input -->
                <TextBlock Text="Input" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding InputPath}" IsReadOnly="True" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0"
                            Command="{Binding PickInputCommand}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}"/>
                </Grid>

                <!-- Lossy warning -->
                <Border Background="{StaticResource WarnBg}" CornerRadius="3" Padding="10,7"
                        Margin="0,0,0,10"
                        Visibility="{Binding IsLossyInput, Converter={StaticResource BoolVis}}">
                    <TextBlock Foreground="{StaticResource WarnFg}" TextWrapping="Wrap"
                               Text="Lossy input (MP3 / AAC / OGG / etc). Re-encoding a lossy file degrades quality further. Use a lossless source where possible."/>
                </Border>

                <!-- Preview player -->
                <Border Background="{StaticResource PanelBg}" CornerRadius="4" Padding="10,8"
                        Margin="0,0,0,16">
                    <Grid IsEnabled="{Binding HasPreview}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="{Binding PlayPauseLabel}"
                                Command="{Binding PlayPauseCommand}"
                                MinWidth="64" Padding="8,4" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CurrentPositionText}"
                                   VerticalAlignment="Center"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{StaticResource SubtleFg}"
                                   Margin="0,0,8,0"/>
                        <Slider Grid.Column="2" x:Name="ScrubSlider"
                                Value="{Binding CurrentPositionSeconds, Mode=OneWay}"
                                Maximum="{Binding TotalDurationSeconds}"
                                VerticalAlignment="Center"
                                Thumb.DragStarted="ScrubSlider_DragStarted"
                                Thumb.DragCompleted="ScrubSlider_DragCompleted"/>
                        <TextBlock Grid.Column="3"
                                   Text="{Binding TotalDurationText}"
                                   VerticalAlignment="Center"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{StaticResource SubtleFg}"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Output -->
                <TextBlock Text="Output  (always WAV)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0"
                            Command="{Binding PickOutputCommand}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}"/>
                </Grid>

                <!-- Tempo -->
                <Grid Margin="0,0,0,5">
                    <TextBlock Text="Tempo" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding TempoDisplay}" HorizontalAlignment="Right"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="{StaticResource SubtleFg}"/>
                </Grid>
                <Slider Value="{Binding TempoPercent}" Minimum="50" Maximum="200"
                        TickFrequency="25" TickPlacement="BottomRight"
                        Margin="0,0,0,5"
                        IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}"/>
                <Button Content="Reset" HorizontalAlignment="Right" Padding="10,3"
                        Command="{Binding ResetTempoCommand}" Margin="0,0,0,24"
                        IsEnabled="{Binding IsRunning, Converter={StaticResource InvBool}}"/>

                <!-- Run / Cancel -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Run" Style="{StaticResource AccentButton}"
                            Command="{Binding RunCommand}"
                            FontSize="14" Padding="24,8" MinWidth="110"/>
                    <Button Content="Cancel" Command="{Binding RunCancelCommand}"
                            Margin="8,0,0,0" FontSize="14" Padding="16,8" MinWidth="90"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"/>

        <!-- Log -->
        <Grid Grid.Row="3" Background="#181818">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="{StaticResource PanelBg}" Padding="12,5">
                <Grid>
                    <TextBlock Text="Log" FontSize="11" Foreground="{StaticResource SubtleFg}"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Copy" Command="{Binding CopyLogCommand}"
                                Padding="8,2" MinWidth="54" Margin="0,0,6,0"/>
                        <Button Content="Save" Command="{Binding SaveLogCommand}"
                                Padding="8,2" MinWidth="54"/>
                    </StackPanel>
                </Grid>
            </Border>
            <ScrollViewer Grid.Row="1" x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding LogLines}" Padding="10,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                       Foreground="#CCCCCC" TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

    </Grid>
</Window>
